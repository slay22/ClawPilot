# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# GitHub — Copilot token (Settings > Developer settings > Personal access tokens)
GITHUB_COPILOT_TOKEN=

# GitHub — Fine-grained PAT for MCP (needs: repo read, actions read, issues write)
GITHUB_PAT=

# Tavily Search (free tier at app.tavily.com — 1,000 req/month, no CC)
TAVILY_API_KEY=

# PR Runner — webhook HMAC-SHA256 secret (set the same value in your GitHub/AzDO webhook config)
PR_WEBHOOK_SECRET=

# PR Runner — short-lived PAT used to push auto-fix commits back to PR branches
# GitHub: needs Contents (write) on target repos
# Azure DevOps: needs Code (read & write) on target repos
PR_GIT_PAT=

# PR Runner — override the base runner container image (optional, defaults to claw-pilot-runner:latest)
PR_RUNNER_IMAGE=claw-pilot-runner:latest
