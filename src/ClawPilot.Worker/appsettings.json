{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Telegram": {
    "BotToken": "",
    "ChatId": ""
  },
  "GitHub": {
    "CopilotToken": "",
    "Mcp": {
      "McpUrl": "https://api.githubcopilot.com/mcp/",
      "Pat": "",
      "Tools": ["get_file_contents", "list_pull_requests", "get_workflow_run", "get_workflow_run_logs", "create_issue", "push_files", "create_pull_request"]
    }
  },
  "Dashboard": {
    "Url": "http://localhost:5247/logHub"
  },
  "WebSearch": {
    "TavilyApiKey": ""
  },
  "AgentBudget": {
    "MaxIterations": 15,
    "MaxToolCallsPerSession": 40,
    "Timeout": "00:10:00"
  },
  "Journal": {
    "Verbosity": "Full",
    "RetainThoughtStepsDays": 7
  },
  "ConnectionStrings": {
    "Database": "Host=localhost;Username=postgres;Password=password;Database=postgres",
    "Journal": "Data Source=data/clawpilot.db"
  },
  "Conversation": {
    "HistoryWindowSize": 20,
    "SystemPrompt": ""
  }
}

